<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Categoría -->
        <TextView
            android:id="@+id/tvNombrePresupuesto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Salud"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            app:layout_constraintEnd_toStartOf="@+id/tvCantidad"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Cantidad presupuestada -->
        <TextView
            android:id="@+id/tvCantidad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$200.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2A7F6E"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Categoría (texto pequeño) -->
        <TextView
            android:id="@+id/tvCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Categoría: Salud"
            android:textSize="13sp"
            android:textColor="#64748B"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvNombrePresupuesto" />

        <!-- Fechas -->
        <LinearLayout
            android:id="@+id/layoutFechas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvCategoria">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inicio"
                    android:textSize="11sp"
                    android:textColor="#94A3B8" />

                <TextView
                    android:id="@+id/tvFechaInicio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10/04/2026"
                    android:textSize="13sp"
                    android:textColor="#1E293B" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Final"
                    android:textSize="11sp"
                    android:textColor="#94A3B8" />

                <TextView
                    android:id="@+id/tvFechaFinal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10/05/2026"
                    android:textSize="13sp"
                    android:textColor="#1E293B" />
            </LinearLayout>
        </LinearLayout>

        <!-- Barra de progreso -->
        <ProgressBar
            android:id="@+id/progressBarPresupuesto"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#2A7F6E"
            android:background="#E2E8F0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutFechas" />

        <!-- Saldo y estado -->
        <LinearLayout
            android:id="@+id/layoutSaldo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toStartOf="@+id/tvEstadoPresupuesto"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/progressBarPresupuesto">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo: "
                android:textSize="13sp"
                android:textColor="#64748B" />

            <TextView
                android:id="@+id/tvSaldoDisponible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$187.50"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2A7F6E" />
        </LinearLayout>

        <!-- Estado -->
        <TextView
            android:id="@+id/tvEstadoPresupuesto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Activo"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_estado_activo"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/progressBarPresupuesto" />

        <!-- Línea divisoria -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#E2E8F0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutSaldo" />

        <!-- Botones de acción -->
        <LinearLayout
            android:id="@+id/accionesLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/btnEditar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:lottie_rawRes="@raw/editpresupuesto"
                android:contentDescription="Editar presupuesto" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/btnEliminar"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:lottie_rawRes="@raw/deletepresupuesto"
                android:contentDescription="Eliminar presupuesto" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>