<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Estado vacío cuando no hay datos suficientes -->
    <LinearLayout
        android:id="@+id/emptyStateResumen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/icon_resumen"
            android:tint="#CBD5E1"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aún no hay datos suficientes\npara mostrar el resumen."
            android:textSize="16sp"
            android:textColor="#64748B"
            android:textAlignment="center"
            android:padding="24dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollResumen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="5dp"
        android:background="#F8FAFC">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Gastos de la Semana -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#1E40AF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total gastado esta semana"
                        android:textSize="16sp"
                        android:textColor="#DBEAFE"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvGastosSemana"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:gravity="center" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Gastos por Categoría -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Gastos por categoría"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/containerCategorias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Resumen General -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Resumen general"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginBottom="16dp" />

                    <!-- Presupuesto Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_dot_blue"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Presupuesto total"
                            android:textSize="15sp"
                            android:textColor="#64748B" />

                        <TextView
                            android:id="@+id/tvPresupuestoTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1E40AF" />

                    </LinearLayout>

                    <!-- Gastado Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_dot_red"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Gastado total"
                            android:textSize="15sp"
                            android:textColor="#64748B" />

                        <TextView
                            android:id="@+id/tvGastadoTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#DC2626" />

                    </LinearLayout>

                    <!-- Línea divisoria -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E8F0"
                        android:layout_marginVertical="12dp" />

                    <!-- Saldo Disponible -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_dot_green"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Saldo disponible"
                            android:textSize="15sp"
                            android:textColor="#64748B" />

                        <TextView
                            android:id="@+id/tvTotalActivos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$0.00"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1E40AF" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Sección de Estadísticas -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" Estadísticas"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:gravity="center" />

            <!-- Botón Diario -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGraficaDiaria"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text=" VER GASTOS DIARIOS"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1E40AF"
                android:layout_marginBottom="16dp"
                app:cornerRadius="14dp"
                app:strokeColor="#1E40AF"
                app:strokeWidth="2dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- Botón Semanal -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGraficaSemanal"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text=" VER GASTOS SEMANALES"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1E40AF"
                android:layout_marginBottom="16dp"
                app:cornerRadius="14dp"
                app:strokeColor="#1E40AF"
                app:strokeWidth="2dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- Botón Mensual -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGraficaMensual"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text=" VER GASTOS MENSUALES"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1E40AF"
                android:layout_marginBottom="16dp"
                app:cornerRadius="14dp"
                app:strokeColor="#1E40AF"
                app:strokeWidth="2dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>